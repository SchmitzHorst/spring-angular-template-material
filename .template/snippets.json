{
  "version": "1.0",
  "framework": "tailwind",
  "angularVersion": "17.3",

  "imports": {
    "description": "Standard Angular imports for a Tailwind CRUD component",
    "component": [
      "CommonModule",
      "FormsModule",
      "ReactiveFormsModule"
    ],
    "nav": [
      "CommonModule",
      "RouterLink",
      "RouterLinkActive"
    ],
    "home": [
      "CommonModule",
      "RouterLink"
    ]
  },

  "button": {
    "primary": "<button class=\"bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded\">Label</button>",
    "secondary": "<button class=\"bg-gray-200 hover:bg-gray-300 text-gray-800 font-medium py-2 px-4 rounded\">Label</button>",
    "danger": "<button class=\"bg-red-600 hover:bg-red-700 text-white text-sm py-1 px-3 rounded\">Delete</button>",
    "icon": "<button class=\"text-blue-600 hover:text-blue-800 p-1\" title=\"Tooltip\">✏️</button>"
  },

  "input": {
    "text": "<div class=\"mb-4\">\n  <label class=\"block text-sm font-medium text-gray-700 mb-1\">Label</label>\n  <input type=\"text\" class=\"w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500\" [(ngModel)]=\"model.field\" name=\"field\" required>\n</div>",
    "select": "<div class=\"mb-4\">\n  <label class=\"block text-sm font-medium text-gray-700 mb-1\">Label</label>\n  <select class=\"w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500\" [(ngModel)]=\"model.field\" name=\"field\" required>\n    <option *ngFor=\"let opt of options\" [value]=\"opt.value\">{{ opt.label }}</option>\n  </select>\n</div>",
    "date": "<div class=\"mb-4\">\n  <label class=\"block text-sm font-medium text-gray-700 mb-1\">Date</label>\n  <input type=\"date\" class=\"w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500\" [(ngModel)]=\"model.dateField\" name=\"dateField\">\n</div>",
    "textarea": "<div class=\"mb-4\">\n  <label class=\"block text-sm font-medium text-gray-700 mb-1\">Label</label>\n  <textarea class=\"w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500\" [(ngModel)]=\"model.field\" name=\"field\" rows=\"3\"></textarea>\n</div>"
  },

  "table": {
    "description": "Tailwind table with striped rows",
    "html": "<div class=\"overflow-x-auto\">\n  <table class=\"min-w-full bg-white border border-gray-200 rounded-lg\">\n    <thead class=\"bg-gray-50\">\n      <tr>\n        <th class=\"px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider\">Column 1</th>\n        <th class=\"px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider\">Actions</th>\n      </tr>\n    </thead>\n    <tbody class=\"divide-y divide-gray-200\">\n      <tr *ngFor=\"let item of items; let i = index\" [class.bg-gray-50]=\"i % 2 === 1\">\n        <td class=\"px-4 py-3 text-sm text-gray-900\">{{ item.col1 }}</td>\n        <td class=\"px-4 py-3 text-sm\">\n          <button class=\"text-blue-600 hover:text-blue-800 mr-2\" (click)=\"selectForEdit(item)\">Edit</button>\n          <button class=\"text-red-600 hover:text-red-800\" (click)=\"delete(item.id!)\">Delete</button>\n        </td>\n      </tr>\n      <tr *ngIf=\"items.length === 0\">\n        <td colspan=\"2\" class=\"px-4 py-3 text-center text-sm text-gray-500\">No data found.</td>\n      </tr>\n    </tbody>\n  </table>\n</div>"
  },

  "card": {
    "basic": "<div class=\"bg-white rounded-lg shadow p-6\">\n  <h3 class=\"text-lg font-semibold text-gray-800 mb-2\">Title</h3>\n  <p class=\"text-gray-600\">Content</p>\n  <button class=\"mt-4 bg-blue-600 hover:bg-blue-700 text-white py-2 px-4 rounded\">Action</button>\n</div>",
    "form": "<div class=\"bg-white rounded-lg shadow p-6\">\n  <h3 class=\"text-lg font-semibold text-gray-800 mb-4\">{{ selectedItem?.id ? 'Edit' : 'New' }} Entity</h3>\n  <form #form=\"ngForm\" (ngSubmit)=\"save()\">\n    <!-- inputs here -->\n    <div class=\"flex gap-2 mt-4\">\n      <button type=\"submit\" class=\"bg-blue-600 hover:bg-blue-700 text-white py-2 px-4 rounded\" [disabled]=\"form.invalid\">Save</button>\n      <button type=\"button\" class=\"bg-gray-200 hover:bg-gray-300 text-gray-800 py-2 px-4 rounded\" (click)=\"reset()\">Cancel</button>\n    </div>\n  </form>\n</div>"
  },

  "navbar": {
    "description": "Tailwind navbar with responsive hamburger",
    "html": "<nav class=\"bg-blue-600 text-white px-6 py-4\">\n  <div class=\"flex items-center justify-between\">\n    <a routerLink=\"/home\" class=\"text-xl font-bold hover:text-blue-200\">App</a>\n    <ul class=\"flex gap-6\">\n      <li><a routerLink=\"/home\" routerLinkActive=\"underline\" class=\"hover:text-blue-200\">Home</a></li>\n      <!-- NAV_ITEMS -->\n    </ul>\n  </div>\n</nav>"
  },

  "listView": {
    "description": "Two-column Tailwind layout: table left, form right",
    "html": "<div class=\"p-6\">\n  <div class=\"flex items-center justify-between mb-4\">\n    <h2 class=\"text-2xl font-bold text-gray-800\">ENTITY_PLURAL</h2>\n    <button class=\"bg-blue-600 hover:bg-blue-700 text-white py-2 px-4 rounded\" *ngIf=\"!selectedItem\" (click)=\"startCreate()\">+ New ENTITY</button>\n  </div>\n  <div class=\"flex gap-6 items-start\">\n    <div class=\"flex-1\"><!-- Tailwind table here --></div>\n    <div class=\"w-1/3\" *ngIf=\"selectedItem\"><!-- Tailwind card form here --></div>\n  </div>\n</div>"
  },

  "promptHints": {
    "description": "Rules the AI MUST follow when generating Tailwind CSS Angular components",
    "rules": [
      "ALWAYS use Tailwind CSS utility classes. NEVER use Bootstrap, Angular Material, or bare unstyled HTML.",
      "Container: <div class=\"p-6\"> or <div class=\"max-w-7xl mx-auto p-6\"> for page content.",
      "Table: <table class=\"min-w-full bg-white border border-gray-200 rounded-lg\"> with <thead class=\"bg-gray-50\"> and <tbody class=\"divide-y divide-gray-200\">.",
      "Primary button: class=\"bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded\"",
      "Secondary button: class=\"bg-gray-200 hover:bg-gray-300 text-gray-800 font-medium py-2 px-4 rounded\"",
      "Danger button: class=\"bg-red-600 hover:bg-red-700 text-white text-sm py-1 px-3 rounded\"",
      "Form inputs: class=\"w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500\"",
      "Labels: <label class=\"block text-sm font-medium text-gray-700 mb-1\">",
      "Form group wrapper: <div class=\"mb-4\">",
      "Card for forms: <div class=\"bg-white rounded-lg shadow p-6\">",
      "Two-column layout: <div class=\"flex gap-6 items-start\"> with <div class=\"flex-1\"> and <div class=\"w-1/3\">",
      "Use browser confirm() for delete confirmation.",
      "All components must be standalone: true.",
      "NgModel binding: [(ngModel)]=\"selectedItem.field\" — always add name attribute.",
      "NEVER use mat-* elements, Bootstrap classes (btn, col-md-*, etc.), or PrimeNG/Ionic components.",
      "NEVER import Angular Material from @angular/material.",
      "Striped table rows: use [class.bg-gray-50]=\"i % 2 === 1\" with let i = index in *ngFor."
    ]
  }
}
